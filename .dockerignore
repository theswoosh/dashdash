# Version control
.git

# Local installs — Docker installs fresh inside the build stages
**/node_modules

# Local build outputs — Docker builds fresh inside the build stages
**/dist

# Sensitive runtime config — mounted as a volume, never baked into the image
config/
!config/*.example

# Dev / CI / docs — not needed in the image
.github/
docs/
memory/
.env*
docker-compose.yml
*.md
