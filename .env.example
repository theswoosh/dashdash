# Copy to .env and fill in values. Never commit .env.

NODE_ENV=development
PORT=4000
DATA_DIR=./data
CONFIG_DIR=./config

# --- OIDC / SSO (optional) ---
# OIDC is auto-enabled when ISSUER + CLIENT_ID + SECRET are all set.
DASHDASH_OIDC_ISSUER=
DASHDASH_OIDC_CLIENT_ID=
DASHDASH_OIDC_SECRET=
DASHDASH_OIDC_SCOPES=openid profile email
DASHDASH_OIDC_GROUPS_CLAIM=
DASHDASH_OIDC_ADMIN_GROUP=
DASHDASH_OIDC_AUTO_LINK=true

# Integration API keys — one per integration ID
# Format: DASHDASH_INTEGRATION_<ID_UPPERCASE>_KEY
DASHDASH_INTEGRATION_SONARR_MAIN_KEY=
DASHDASH_INTEGRATION_RADARR_MAIN_KEY=
DASHDASH_INTEGRATION_PIHOLE_MAIN_KEY=
DASHDASH_INTEGRATION_JELLYFIN_MAIN_KEY=

# Proxmox token (different format)
DASHDASH_INTEGRATION_PVE_HOME_TOKEN_ID=
DASHDASH_INTEGRATION_PVE_HOME_TOKEN_SECRET=

# --- GitHub update-check (optional) ---
# Fine-grained PAT with read-only "Contents" repo scope on theswoosh/dashdash
# (private repo — a public repo would need no token). Absent = feature is a no-op.
DASHDASH_GITHUB_TOKEN=
