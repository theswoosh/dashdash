# Copy to .env and fill in values. Never commit .env.

NODE_ENV=development
PORT=4000
DATA_DIR=./data
CONFIG_DIR=./config

# --- OIDC / SSO (optional) ---
# OIDC is auto-enabled when ISSUER + CLIENT_ID + SECRET are all set.
BOARD_OIDC_ISSUER=
BOARD_OIDC_CLIENT_ID=
BOARD_OIDC_SECRET=
BOARD_OIDC_SCOPES=openid profile email
BOARD_OIDC_GROUPS_CLAIM=
BOARD_OIDC_ADMIN_GROUP=
BOARD_OIDC_AUTO_LINK=true

# Integration API keys — one per integration ID
# Format: BOARD_INTEGRATION_<ID_UPPERCASE>_KEY
BOARD_INTEGRATION_SONARR_MAIN_KEY=
BOARD_INTEGRATION_RADARR_MAIN_KEY=
BOARD_INTEGRATION_PIHOLE_MAIN_KEY=
BOARD_INTEGRATION_JELLYFIN_MAIN_KEY=

# Proxmox token (different format)
BOARD_INTEGRATION_PVE_HOME_TOKEN_ID=
BOARD_INTEGRATION_PVE_HOME_TOKEN_SECRET=

# --- GitHub update-check (optional) ---
# Fine-grained PAT with read-only "Contents" repo scope on theswoosh/dashdash
# (private repo — a public repo would need no token). Absent = feature is a no-op.
BOARD_GITHUB_TOKEN=
