{
  "name": "dashdash",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "dev": "pnpm --filter @dashdash/types build && pnpm --parallel -r run dev",
    "build": "pnpm -r run build",
    "lint": "eslint packages/*/src",
    "typecheck": "pnpm --filter @dashdash/types build && pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx,css}\"",
    "kill-dev": "bash scripts/kill-dev.sh"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ],
    "overrides": {
      "minimatch": "^10.2.3",
      "rollup": "^4.59.0",
      "@jridgewell/trace-mapping": "^0.3.31"
    }
  }
}
