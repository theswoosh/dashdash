# Named integrations — credentials via environment variables only.
# API keys and secrets are NEVER stored in this file.

- id: pihole-main
  type: pihole
  url: http://pihole
  # apiKey via env: BOARD_INTEGRATION_PIHOLE_MAIN_KEY

- id: jellyfin-main
  type: jellyfin
  url: http://jellyfin:8096
  # apiKey via env: BOARD_INTEGRATION_JELLYFIN_MAIN_KEY
