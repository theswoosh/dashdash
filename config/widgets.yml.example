# Widget template defaults — edit to change sizes and constraints for each widget type.
# defaultSize: initial size when dropped from the sidebar.
# minSize:     minimum size the user can resize to.

- type: clock
  defaultSize: { w: 2, h: 2 }
  minSize: { w: 2, h: 2 }

- type: healthcheck
  defaultSize: { w: 2, h: 2 }
  minSize: { w: 2, h: 2 }

- type: stats
  defaultSize: { w: 3, h: 3 }
  minSize: { w: 2, h: 2 }

- type: bookmarks
  defaultSize: { w: 2, h: 2 }
  minSize: { w: 2, h: 2 }

- type: search
  defaultSize: { w: 3, h: 2 }
  minSize: { w: 3, h: 2 }

- type: notepad
  defaultSize: { w: 3, h: 3 }
  minSize: { w: 2, h: 2 }

- type: iframe
  defaultSize: { w: 4, h: 4 }
  minSize: { w: 2, h: 2 }

- type: frame
  defaultSize: { w: 6, h: 4 }
  minSize: { w: 2, h: 2 }
