# Widget template defaults — initial size when a widget is dropped from the sidebar.
#
# Sizes are in grid units. One unit = cellSize + gap = 14 px by default (10 + 4),
# so a widget's pixel size is roughly  w × 14 − 4  px.
#   Examples: 14 units ≈ 192 px · 35 units ≈ 486 px · 70 units ≈ 976 px
#
# How many units fit on screen (grid fills the window width):
#   1366 px laptop ≈ 97 units · 1920 px ≈ 137 units · 2560 px ≈ 183 units · 4K ≈ 274 units
#
# Max per dimension: 500 units. There is no minimum — widgets can be resized
# freely down to 1×1 in the UI; defaultSize only applies at drop time.

- type: clock
  defaultSize: { w: 35, h: 35 }

- type: healthcheck
  defaultSize: { w: 14, h: 14 }

- type: stats
  defaultSize: { w: 35, h: 28 }

- type: bookmarks
  defaultSize: { w: 28, h: 28 }

- type: search
  defaultSize: { w: 42, h: 14 }

- type: notepad
  defaultSize: { w: 42, h: 35 }

- type: iframe
  defaultSize: { w: 56, h: 49 }

- type: frame
  defaultSize: { w: 84, h: 56 }
