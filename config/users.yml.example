# Local user definitions. Only used when auth.local.enabled = true in settings.yml.
# Passwords are hashed with bcrypt on first load and replaced with the hash.
# OIDC users are created automatically in the database on first login.

- username: admin
  email: admin@example.com
  role: admin
  # password via env: DASHDASH_USER_ADMIN_PASSWORD
  # Or set a bcrypt hash directly:
  # passwordHash: "$2b$12$..."
