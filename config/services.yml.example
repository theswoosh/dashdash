# Widget instances. Each service maps to a widget type.
# layout values are in grid units (1 unit = grid cellSize px, default 10).

- title: Clock
  widget: clock
  layout:
    w: 8
    h: 8
    x: 0
    y: 0
  options:
    timezone: Europe/Berlin
    format: 24h

- title: Search
  widget: search
  layout:
    w: 12
    h: 4
    x: 0
    y: 9
  options:
    engine: duckduckgo          # duckduckgo | google | brave | custom
    # customUrl: https://search.example.com/?q=

- title: Servers
  widget: frame
  layout:
    w: 24
    h: 16
    x: 0
    y: 14
  children:
    - title: Healthcheck
      widget: healthcheck
      layout: { w: 4, h: 4, x: 0, y: 0 }
      options:
        url: 192.168.1.1
        ping: true
    - title: System Stats
      widget: stats
      layout: { w: 10, h: 8, x: 5, y: 0 }
