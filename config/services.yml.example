# Widget instances. Each service maps to a widget type.
# layout.x/y are defaults; user overrides are stored in the database.

- title: Clock
  widget: clock
  layout:
    w: 2
    h: 2
    x: 0
    y: 0
  options:
    timezone: Europe/Berlin
    format: 24h

- title: Search
  widget: search
  layout:
    w: 6
    h: 1
    x: 0
    y: 2
  options:
    engine: duckduckgo          # duckduckgo | google | brave | custom
    # customUrl: https://search.example.com/?q=

- title: Servers
  widget: frame
  layout:
    w: 8
    h: 6
    x: 0
    y: 4
  children:
    - title: Healthcheck
      widget: healthcheck
      layout: { w: 2, h: 2, x: 0, y: 0 }
      options:
        url: 192.168.1.1
        ping: true
    - title: System Stats
      widget: stats
      layout: { w: 3, h: 3, x: 2, y: 0 }
