# Widget instances — this file seeds a fresh install's starter board.
# Layout values are in fine-grid units (1 unit = cellSize + gap = 14 px by
# default), so e.g. w: 14 ≈ 192 px. Positions/sizes update automatically when
# you drag or resize widgets in edit mode. `id` is optional in hand-written
# entries (assigned from the widget type at load) and is persisted on the
# first UI-triggered write — don't reuse the same id twice.
#
# Add more widgets in the UI: Config (top-right) → Add Widgets → drag onto
# the grid. Available types: clock, healthcheck, stats, bookmarks, search,
# notepad, iframe, frame.

- title: Clock
  widget: clock
  layout: { w: 14, h: 9, x: 0, y: 0 }
  options:
    format: 24h        # 24h | 12h
    # timezone: Europe/Berlin — defaults to the browser's zone
    # showTimezone: true — zone name + GMT offset below the clock

- title: Search
  widget: search
  layout: { w: 16, h: 8, x: 16, y: 0 }
  # Uses the first engine from settings.yml unless one is picked here.
  # options:
  #   engine: duckduckgo

- title: System Stats
  widget: stats
  layout: { w: 14, h: 14, x: 0, y: 11 }
