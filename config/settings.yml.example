title: "Home"
theme: glass           # glass | dark | light | custom

background:
  type: gradient       # image | gradient | color | unsplash | video
  # For type: image
  # url: /config/backgrounds/my-bg.jpg
  # For type: gradient (CSS gradient string)
  value: "linear-gradient(135deg, #0f0f1a 0%, #1a0f2e 50%, #0a1a2e 100%)"
  blur: 0              # blur applied to bg layer only (px)
  overlay: "rgba(0,0,0,0.35)"
  parallax: false

# Advanced, YAML-only — no UI. Square cells; column count fills the viewport.
# Changing cellSize rescales all widget layouts (stored in grid units).
grid:
  cellSize: 10         # px per square cell
  gap: 4               # px gap between cells

auth:
  local:
    enabled: true      # set to false to disable local login when OIDC is the only method

# Search engines for the header bar and search widget.
# All engines must be defined here — there are no built-in defaults.
# If this section is absent or empty, search is disabled everywhere.
# Engine placeholder text is optional; widget options can override it.
searchEngines:
  - id: qwant
    label: qwant
    url: https://www.qwant.com/?q={query}
    placeholder: Search qwant…
  - id: duckduckgo
    label: DuckDuckGo
    url: https://duckduckgo.com/?q={query}
    placeholder: Search DuckDuckGo…
  - id: brave
    label: Brave
    url: https://search.brave.com/search?q={query}
    placeholder: Search Brave…
  - id: google
    label: Google
    url: https://www.google.com/search?q={query}
    placeholder: Search Google…

# Allow healthchecks against private/reserved addresses (RFC-1918, loopback,
# link-local). On by default for homelab use where widgets ping LAN hosts
# like 192.168.x.x — set to false as an SSRF guard on multi-user or
# internet-exposed deployments.
allowPrivateNetworks: true

# Optional: custom CSS injected after theme
css:
  custom: |
    :root {
      --accent: #7c3aed;
    }
