{
  "name": "@dashdash/backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "node --watch --loader ts-node/esm src/server.ts",
