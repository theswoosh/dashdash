    "fastify": "^5.2.1",
    "js-yaml": "^4.1.0",
    "nodemailer": "^8.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^7.0.11",
