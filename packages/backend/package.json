{
  "name": "@dashdash/backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "files": [
    "dist",
    "seed"
  ],
  "scripts": {
    "dev": "node --watch --loader ts-node/esm src/server.ts",
    "build": "tsc && cp -r src/db/migrations dist/db/migrations",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^9.0.0",
    "@fastify/websocket": "^11.0.2",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "chokidar": "^5.0.0",
    "fastify": "^5.8.2",
    "js-yaml": "^4.1.0",
    "nodemailer": "^8.0.2",
    "openid-client": "^6.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@dashdash/types": "workspace:*",
    "@types/better-sqlite3": "^7.6.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^7.0.11",
    "@types/ws": "^8.18.1",
    "pino-pretty": "^13.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.0"
  }
}
